# Lumina Voyage Environment Variables

# Server
PORT=3000
NODE_ENV=development

# Google Maps (provided via Replit integration)
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# Gemini AI API Key (for translation & trip planning)
GEMINI_API_KEY=

# CORS allowed origins (comma-separated, defaults to localhost)
# CORS_ORIGINS=https://your-domain.replit.app

# Optional: Analytics
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
